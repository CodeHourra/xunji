{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "寻迹",
  "version": "0.1.3",
  "identifier": "com.xunji.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun --bun run dev",
    "beforeBuildCommand": "bun --bun run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "寻迹 - AI 编程知识平台",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": {
      "../../../packages/sidecar/dist/xunji-sidecar": "xunji-sidecar"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlENzEzM0RBODkxQ0Y3QTEKUldTaDl4eUoyak54blV5a2huR0h2dUxML3ozYXE1enhtTHlMbzc1NEVaakJld010N1NmUXFjdXgK",
      "endpoints": [
        "https://github.com/CodeHourra/xunji/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
